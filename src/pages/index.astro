---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";
import heroImage from "../assets/hero.png";
import bannerImage from "../assets/banner.png";
import imgColaborativa from "../assets/products/colaborativa.png";
import imgLogistica from "../assets/products/logistica.png";
import imgTradicional from "../assets/products/tradicional.png";

const siteUrl = Astro.site ?? new URL("http://localhost:4321");
const absolute = (path: string) => new URL(path, siteUrl).href;

const slideImages: Record<string, ImageMetadata> = {
  colaborativa: bannerImage,
  movil: heroImage,
};

const productImages: Record<string, ImageMetadata> = {
  "robotica-colaborativa": imgColaborativa,
  "robotica-logistica": imgLogistica,
  "robotica-tradicional": imgTradicional,
};

const partnerModules = import.meta.glob<{ default: ImageMetadata }>("../assets/partners/*.png", { eager: true });
const partners = Object.entries(partnerModules)
  .map(([path, mod]) => ({
    src: mod.default,
    name: path.split("/").pop()!.replace(/\.png$/, "").replace(/-/g, " "),
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.legalName,
  alternateName: siteConfig.name,
  description: siteConfig.description,
  url: new URL(Astro.url.pathname, siteUrl).href,
  logo: absolute(siteConfig.defaultImage),
  image: absolute(siteConfig.defaultImage),
  telephone: siteConfig.phone,
  email: siteConfig.email,
  slogan: siteConfig.tagline,
  areaServed: "ES",
  address: siteConfig.locations.map((location) => ({
    "@type": "PostalAddress",
    streetAddress: location.address,
    addressLocality: location.city,
    addressRegion: location.region,
    addressCountry: "ES",
  })),
  sameAs: siteConfig.social.map((item) => item.href),
};
---

<BaseLayout image={siteConfig.defaultImage} structuredData={structuredData}>
  <Nav />

  <main id="main">
    <section id="top" class="hero hero-slider" aria-label="Presentación">
      <h1 class="visually-hidden">Robotplus — robótica colaborativa, móvil y tradicional</h1>
      {homeContent.hero.slides.map((slide, index) => (
        <div class="hero-slide" data-active={index === 0 ? "true" : "false"}>
          <Image
            class="media-fill"
            src={slideImages[slide.image]}
            alt={`Robótica ${slide.title[1]}`}
            widths={[768, 1280, 1920]}
            sizes="100vw"
            loading={index === 0 ? "eager" : "lazy"}
            decoding={index === 0 ? "sync" : "async"}
          />
          <div class="overlay" style="background: var(--grad-vignette);"></div>
          <div class="overlay" style="background: var(--grad-veil);"></div>
          <div class="hero-content">
            <div class="hero-grid">
              <div class="hero-heading">
                <p class="label-eyebrow">{slide.eyebrow}</p>
                <p class="hero-title display">
                  {slide.title[0]}<br />
                  <span class="display-italic grad-text">{slide.title[1]}</span>
                </p>
              </div>

              <div class="hero-copy">
                <p>{slide.body}</p>
                <div class="hero-actions">
                  <a class="button-link" href={slide.href}>{slide.action} <span aria-hidden="true">-&gt;</span></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
      <div class="hero-dots">
        {homeContent.hero.slides.map((_, index) => (
          <button type="button" class={index === 0 ? "is-on" : ""} data-i={index} aria-label={`Diapositiva ${index + 1}`}></button>
        ))}
      </div>
    </section>

    <!-- Nuestros servicios -->
    <section id="servicios" class="section services-section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.servicesNav.heading}</h2>
        <ul class="services-nav reveal">
          {homeContent.servicesNav.items.map((item) => (
            <li>
              <a href={item.href}>
                <span class="services-nav__icon" aria-hidden="true">{item.icon}</span>
                <span class="services-nav__label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Bloques de producto -->
    {homeContent.products.map((product, index) => (
      <section id={product.id} class={`section product-section ${index % 2 === 1 ? "surface-section" : ""}`}>
        <div class={`container product ${index % 2 === 1 ? "product--reverse" : ""}`}>
          <div class="product-media reveal">
            <Image
              src={productImages[product.id]}
              alt={product.title}
              widths={[480, 768, 1000]}
              sizes="(max-width: 900px) 90vw, 45vw"
              loading="lazy"
            />
          </div>
          <div class="product-copy reveal reveal-delay-1">
            <h3 class="product-title display">{product.title}</h3>
            <p>{product.body}</p>
            <a class="button-link" href="#contacto">{product.action} <span aria-hidden="true">-&gt;</span></a>
          </div>
        </div>
      </section>
    ))}

    <!-- Soluciones por sector -->
    <section id="sectores" class="section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.sectors.heading}</h2>
        <ul class="sectors-row reveal">
          {homeContent.sectors.items.map((sector) => (
            <li>
              <span class="sector-icon" aria-hidden="true">{sector.icon}</span>
              <span class="sector-title">{sector.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Partners -->
    <section id="partners" class="section surface-section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.partners.heading}</h2>
        <div class="partners-strip reveal">
          {partners.map((partner) => (
            <Image class="partner-logo" src={partner.src} alt={partner.name} height={44} loading="lazy" />
          ))}
        </div>
      </div>
    </section>

    <!-- Contacto -->
    <section id="contacto" class="section reservation">
      <div class="overlay" style="background: var(--grad-vignette);"></div>

      <div class="container section-grid">
        <div class="reservation-copy">
          <p class="label-eyebrow reveal">Contacto</p>
          <h2 class="display reveal">{homeContent.contact.heading}</h2>
          <div class="reservation-facts reveal reveal-delay-2">
            <div>
              <p class="label-eyebrow">Teléfono</p>
              <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
            </div>
            <div>
              <p class="label-eyebrow">Email</p>
              <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
            </div>
          </div>
          <div class="locations reveal reveal-delay-2">
            <p class="label-eyebrow">Sedes</p>
            <ul>
              {siteConfig.locations.map((location) => (
                <li>{location.address} · {location.city}{location.region ? `, ${location.region}` : ""}</li>
              ))}
            </ul>
          </div>
        </div>

        <form class="reservation-form reveal" action={siteConfig.contactForm.formAction} method={siteConfig.contactForm.method} enctype="text/plain">
          <div class="form-grid">
            <div class="form-field--full">
              <label class="label-eyebrow" for="name">Tu nombre <span aria-hidden="true">*</span></label>
              <input id="name" name="name" autocomplete="name" required />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="email">Tu correo electrónico <span aria-hidden="true">*</span></label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="phone">Tu número de teléfono</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="subject">Asunto</label>
              <input id="subject" name="subject" />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="message">Tu mensaje (opcional)</label>
              <textarea id="message" name="message" rows="4"></textarea>
            </div>
          </div>
          <p class="legal-text">{homeContent.contact.legal}</p>
          <label class="privacy-check">
            <input type="checkbox" name="privacy" required />
            <span>{homeContent.contact.privacyLabel}</span>
          </label>
          <button class="form-button" type="submit">{homeContent.contact.action} <span aria-hidden="true">-&gt;</span></button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const root = document.querySelector(".hero-slider");
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".hero-dots button"));
    let current = 0;
    let timer: number | undefined;

    const show = (next: number) => {
      slides[current].dataset.active = "false";
      dots[current]?.classList.remove("is-on");
      current = (next + slides.length) % slides.length;
      slides[current].dataset.active = "true";
      dots[current]?.classList.add("is-on");
    };

    const start = () => {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce || slides.length < 2) return;
      timer = window.setInterval(() => show(current + 1), 5500);
    };

    dots.forEach((dot, index) =>
      dot.addEventListener("click", () => {
        window.clearInterval(timer);
        show(index);
        start();
      }),
    );

    start();
  }
</script>
