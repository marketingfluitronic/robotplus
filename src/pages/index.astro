---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import RobotMark from "../components/RobotMark.astro";
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";

const siteUrl = Astro.site ?? new URL("http://localhost:4321");
const absolute = (path: string) => new URL(path, siteUrl).href;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.legalName,
  alternateName: siteConfig.name,
  description: siteConfig.description,
  url: new URL(Astro.url.pathname, siteUrl).href,
  logo: absolute(siteConfig.defaultImage),
  image: absolute(siteConfig.defaultImage),
  telephone: siteConfig.phone,
  email: siteConfig.email,
  slogan: siteConfig.tagline,
  areaServed: "ES",
  address: siteConfig.locations.map((location) => ({
    "@type": "PostalAddress",
    streetAddress: location.address,
    addressLocality: location.city,
    addressRegion: location.region,
    addressCountry: "ES",
  })),
  sameAs: siteConfig.social.map((item) => item.href),
};

const imageCaption: Record<string, string> = {
  cobot: "Imagen: brazo colaborativo (Universal Robots)",
  amr: "Imagen: AMR MiR",
  yamaha: "Imagen: robot cartesiano Yamaha",
};
---

<BaseLayout image={siteConfig.defaultImage} structuredData={structuredData}>
  <Nav />

  <main id="main">
    <section id="top" class="hero" aria-labelledby="hero-title">
      <div class="hero-bg" aria-hidden="true">
        <div class="layer hero-grid-lines"></div>
        <div class="layer hero-glow"></div>
        <div class="layer hero-stars"></div>
        <RobotMark class="hero-robot hero-robot--left" />
        <RobotMark class="hero-robot hero-robot--right" />
      </div>
      <div class="overlay" style="background: var(--grad-vignette);"></div>
      <div class="overlay" style="background: var(--grad-veil);"></div>
      <div class="hero-content">
        <div class="hero-grid">
          <div class="hero-heading">
            <p class="label-eyebrow reveal">{homeContent.hero.eyebrow}</p>
            <h1 id="hero-title" class="hero-title display reveal reveal-delay-1">
              {homeContent.hero.title[0]}<br />
              <span class="display-italic grad-text">{homeContent.hero.title[1]}</span>
            </h1>
          </div>

          <div class="hero-copy reveal reveal-delay-2">
            <p>{homeContent.hero.body}</p>
            <div class="hero-actions">
              <a class="button-link" href="#servicios">{homeContent.hero.action} <span aria-hidden="true">-&gt;</span></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Nuestros servicios -->
    <section id="servicios" class="section services-section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.servicesNav.heading}</h2>
        <ul class="services-nav reveal">
          {homeContent.servicesNav.items.map((item) => (
            <li>
              <a href={item.href}>
                <span class="services-nav__icon" aria-hidden="true">{item.icon}</span>
                <span class="services-nav__label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Bloques de producto -->
    {homeContent.products.map((product, index) => (
      <section id={product.id} class={`section product-section ${index % 2 === 1 ? "surface-section" : ""}`}>
        <div class={`container product ${index % 2 === 1 ? "product--reverse" : ""}`}>
          <div class="product-media image-frame aspect-16-10 brand-panel brand-panel--wide reveal">
            <span class="panel-tag label-eyebrow">{imageCaption[product.image]}</span>
          </div>
          <div class="product-copy reveal reveal-delay-1">
            <h3 class="product-title display">{product.title}</h3>
            <p>{product.body}</p>
            <a class="button-link" href="#contacto">{product.action} <span aria-hidden="true">-&gt;</span></a>
          </div>
        </div>
      </section>
    ))}

    <!-- Soluciones por sector -->
    <section id="sectores" class="section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.sectors.heading}</h2>
        <ul class="sectors-row reveal">
          {homeContent.sectors.items.map((sector) => (
            <li>
              <span class="sector-icon" aria-hidden="true">{sector.icon}</span>
              <span class="sector-title">{sector.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Partners -->
    <section id="partners" class="section surface-section">
      <div class="container">
        <h2 class="services-title display reveal">{homeContent.partners.heading}</h2>
        <ul class="partners-row reveal">
          {homeContent.partners.items.map((partner) => (
            <li class="partner-logo">{partner}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Contacto -->
    <section id="contacto" class="section reservation">
      <div class="overlay" style="background: var(--grad-vignette);"></div>

      <div class="container section-grid">
        <div class="reservation-copy">
          <p class="label-eyebrow reveal">Contacto</p>
          <h2 class="display reveal">{homeContent.contact.heading}</h2>
          <div class="reservation-facts reveal reveal-delay-2">
            <div>
              <p class="label-eyebrow">Teléfono</p>
              <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
            </div>
            <div>
              <p class="label-eyebrow">Email</p>
              <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
            </div>
          </div>
          <div class="locations reveal reveal-delay-2">
            <p class="label-eyebrow">Sedes</p>
            <ul>
              {siteConfig.locations.map((location) => (
                <li>{location.address} · {location.city}{location.region ? `, ${location.region}` : ""}</li>
              ))}
            </ul>
          </div>
        </div>

        <form class="reservation-form reveal" action={siteConfig.contactForm.formAction} method={siteConfig.contactForm.method} enctype="text/plain">
          <div class="form-grid">
            <div class="form-field--full">
              <label class="label-eyebrow" for="name">Tu nombre <span aria-hidden="true">*</span></label>
              <input id="name" name="name" autocomplete="name" required />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="email">Tu correo electrónico <span aria-hidden="true">*</span></label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="phone">Tu número de teléfono</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="subject">Asunto</label>
              <input id="subject" name="subject" />
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="message">Tu mensaje (opcional)</label>
              <textarea id="message" name="message" rows="4"></textarea>
            </div>
          </div>
          <p class="legal-text">{homeContent.contact.legal}</p>
          <label class="privacy-check">
            <input type="checkbox" name="privacy" required />
            <span>{homeContent.contact.privacyLabel}</span>
          </label>
          <button class="form-button" type="submit">{homeContent.contact.action} <span aria-hidden="true">-&gt;</span></button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
