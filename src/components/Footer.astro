---
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <Logo tagline={true} class="footer-logo" />
      <p>{siteConfig.tagline}</p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Síguenos</p>
      <ul>
        {siteConfig.social.map((item) => (
          <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Legal</p>
      <ul>
        {homeContent.footer.legalLinks.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Contacto</p>
      <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
      <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {siteConfig.legalName}. Todos los derechos reservados.</p>
      <p><span class="ember-dot" aria-hidden="true"></span> {siteConfig.tagline}</p>
    </div>
  </div>
</footer>
