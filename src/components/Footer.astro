---
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <strong>{siteConfig.name.toUpperCase()}</strong>
      <p>{homeContent.footer.tagline}</p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Contacto</p>
      <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
      <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Sedes</p>
      <ul>
        {siteConfig.locations.map((location) => (
          <li>{location.city}{location.region ? ` · ${location.region}` : ""}</li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Partners</p>
      <ul>
        {siteConfig.partners.map((partner) => <li>{partner}</li>)}
      </ul>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {siteConfig.legalName}. Todos los derechos reservados.</p>
      <p><span class="ember-dot" aria-hidden="true"></span> {siteConfig.tagline}</p>
    </div>
  </div>
</footer>
